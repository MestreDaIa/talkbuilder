# Copie para .env.local e preencha com as credenciais do Supabase do TalkMap
# (esse é o banco do SISTEMA — não confundir com o "Bring Your Own Database"
# que cada cliente pode plugar pelas Configurações → Integrações).

VITE_TALKMAP_SUPABASE_URL=https://your-project.supabase.co
VITE_TALKMAP_SUPABASE_ANON_KEY=sb_publishable_xxx
